    {
        "id": "cb2f12d1b5e0a154",
        "type": "function",
        "z": "c3bacffc40d8e6b4",
        "name": "funcion scanner ",
        "func": "let raw = msg.payload.trim();\n\n// separar por ;\nlet parts = raw.split(\";\");\n\nif (parts.length < 3) {\n  node.warn(\"Formato inesperado: \" + raw);\n  return null;\n}\n\n// quitar P del modelo\nlet model = parts[0].replace(/^P/, \"\");\n\n// serie\nlet sn = parts[2].trim();\n\n// validaciones\nif (!/^S\\d{7}$/.test(sn)) {\n  node.warn(\"SN inválido: \" + sn);\n  return null;\n}\n\nmsg.payload = {\n  model: model,\n  sn: sn,\n  scan_ts: new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 160,
        "wires": [
            [
                "faaed5cef799f41f"
            ]
        ]
    },
