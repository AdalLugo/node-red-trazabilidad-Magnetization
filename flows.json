        "name": "ARM_SYSTEM",
        "func": "// Guardamos la pieza en memoria\nflow.set(\"part\", msg.payload);\n\n// Inicializamos variables\nflow.set(\"state\", \"ARMED\");\nflow.set(\"baseline\", null);\nflow.set(\"trigger_v\", null);\nflow.set(\"trigger_ts\", null);\n\nnode.status({fill:\"green\",shape:\"dot\",text:\"ARMED\"});\n\nreturn msg;",
